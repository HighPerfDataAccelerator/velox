+bool uses_fixed_point(table_view const& table, ast::expression const& expr)
+{
+  if (auto const* lit = dynamic_cast<ast::literal const*>(&expr)) {
+    return cudf::is_fixed_point(lit->get_data_type());
+  }
+  if (auto const* col = dynamic_cast<ast::column_reference const*>(&expr)) {
+    auto const col_index = col->get_column_index();
+    if (col_index >= 0 && col_index < table.num_columns()) {
+      return cudf::is_fixed_point(table.column(col_index).type());
+    }
+  }
+  if (auto const* op = dynamic_cast<ast::operation const*>(&expr)) {
+    for (auto const& operand : op->get_operands()) {
+      if (uses_fixed_point(table, operand.get())) {
+        return true;
+      }
+    }
+  }
+  return false;
+}
